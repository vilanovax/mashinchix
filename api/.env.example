# ——— دیتابیس لوکال با Docker ———
# 1) از ریشهٔ مخزن:  docker compose up -d
# 2) این فایل را به .env کپی کنید:  cp .env.example .env
# 3) مهاجرت:        npx prisma migrate dev
# اگر پورت ۵۴۳۲ روی سیستم اشغال است، در docker-compose.yml مثلاً "5433:5432" کنید
# و اینجا localhost را به 5433 عوض کنید.
DATABASE_URL="postgresql://mashinchi:mashinchi@localhost:5432/mashinchi?schema=public"

PORT=3000

# Redis همان استک Docker (BullMQ). اگر Redis بالا نیست: DISABLE_BULLMQ=true
REDIS_URL="redis://127.0.0.1:6379"
# برای تست بدون Redis: DISABLE_BULLMQ=true

# Cron pipeline: اسکرپ → تجمیع → متریک (زمان‌بندی پیش‌فرض: هر شب ۳)
# DISABLE_DATA_CRON=true
# DATA_CRON="0 3 * * *"
# DATA_JOB_AGGREGATE_DELAY_MS=600000
# DATA_JOB_METRICS_DELAY_MS=1200000
# پیش‌بینی قیمت و شاخص سگمنت، سپس امتیازها (پیش‌فرض: نسبت به تأخیر متریک‌ها)
# DATA_JOB_PREDICTIONS_DELAY_MS=1320000
# DATA_JOB_SCORES_DELAY_MS=1620000
# سیگنال خرید/فروش بعد از امتیازها (پیش‌فرض: +۱۸۰ ثانیه پس از scores)
# DATA_JOB_BUY_SELL_DELAY_MS=1800000
# نقدشوندگی، چرخهٔ بازار، سپس بینش/هشدار بازار، بعد رفتار و ترجیح
# DATA_JOB_LIQUIDITY_STATS_DELAY_MS=
# DATA_JOB_MARKET_CYCLE_DELAY_MS=
# DATA_JOB_INSIGHTS_DELAY_MS=
# DATA_JOB_ALERTS_DELAY_MS=
# DATA_JOB_USER_NOTIFICATIONS_DELAY_MS=
# DATA_JOB_PERSONALIZED_INSIGHTS_DELAY_MS=
# DATA_JOB_MARKET_REPORTS_DELAY_MS=
# رفتار، ترجیح، سپس ارزیابی مدل (پیش‌بینی/امتیاز/توصیه/کالیبراسیون)
# DATA_JOB_BEHAVIOR_METRICS_DELAY_MS=
# DATA_JOB_PREFERENCE_SIGNALS_DELAY_MS=
# DATA_JOB_MODEL_EVALUATION_DELAY_MS=

# API عمومی: /public/* — اگر false باشد بدون کلید هم پاسخ می‌دهد (فقط dev)
# PUBLIC_API_REQUIRE_KEY=false
# ساخت کلید: POST /admin/api-keys با ALLOW_ADMIN_API_KEYS=true

# دیوار (بدنهٔ JSON جستجو؛ اگر خالی باشد بدنهٔ پیش‌فرض در کد استفاده می‌شود)
# DIVAR_SEARCH_URL="https://api.divar.ir/v8/postlist/w/search"
# DIVAR_SEARCH_JSON='{"city_ids":["1"],...}'
# DIVAR_PRICE_DIVISOR=1
# DIVAR_REQUEST_TIMEOUT_MS=25000

# دستی: POST /admin/data-platform/enqueue
# ALLOW_DATA_PLATFORM_ADMIN=true
# ALLOW_ADMIN_API_KEYS=true
# DATA_JOB_CLEAN_DELAY_MS=120000

# کیفیت داده / alias / نظرات / NLP stub
# ALLOW_ADMIN_DATA_QUALITY=true
# CLEANING_RESET_EXCLUSIONS=true

# هزینهٔ مالکیت (OwnershipCost): قیمت لیتر سوخت (تومان) و فرض کیلومتر ماهانه
# FUEL_PRICE_PER_LITER_TOMANS=45000
# ASSUMED_KM_PER_MONTH=1500

# ——— JWT / CORS (احراز هویت) ———
# JWT_SECRET="طولانی-تصادفی-تولید-کنید"
# JWT_REFRESH_SECRET="دیگر-راز-جداساز-تازه‌سازی"
# مبدأ فرانت برای کوکی و credentials (می‌توان چند مقدار با کاما)
# WEB_ORIGIN=http://localhost:3000
