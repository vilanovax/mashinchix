  futureDrawdown     Float?
  futureReturn       Float?
  createdAt          DateTime @default(now())

  @@unique([carId, snapshotDate])
  @@index([snapshotDate])
}

model RecommendationPerformance {
  id                     String                @id @default(cuid())
  recommendationSessionId String               @unique
  recommendationSession  RecommendationSession @relation(fields: [recommendationSessionId], references: [id], onDelete: Cascade)
