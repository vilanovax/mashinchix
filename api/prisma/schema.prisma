}

model AdaptiveExperimentResult {
  id            String   @id @default(cuid())
  experimentId  String
  experiment    AdaptiveExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  metricName    String
  controlValue  Float?
  candidateValue Float?
  winner        String?
  createdAt     DateTime @default(now())

  @@index([experimentId, createdAt])
}

model SignalPerformance {
  id               String          @id @default(cuid())
  signalKey        String
  horizon          LearningHorizon
  periodStart      DateTime        @db.Date
  periodEnd        DateTime        @db.Date
  sampleCount      Int
  successCount     Int
  avgForwardReturn Float?
  winRate          Float?
  rewardScore      Float?
  metadata         Json?
  createdAt        DateTime        @default(now())

  @@unique([signalKey, horizon, periodStart, periodEnd])
  @@index([signalKey, periodEnd])
}

model DecisionOutcome {
  id                     String           @id @default(cuid())
  decisionSnapshotId     String
  decisionSnapshot       DecisionSnapshot @relation(fields: [decisionSnapshotId], references: [id], onDelete: Cascade)
  horizon                LearningHorizon
  benchmarkReturnPct     Float?
  decisionReturnProxyPct Float?
  success                Boolean?
  rewardScore            Float?
  evaluatedAt            DateTime         @default(now())
  metadata               Json?

  @@unique([decisionSnapshotId, horizon])
  @@index([evaluatedAt])
}

model RecommendationOutcome {
  id                     String                 @id @default(cuid())
  recommendationResultId String
  recommendationResult   RecommendationResult     @relation(fields: [recommendationResultId], references: [id], onDelete: Cascade)
  modelVersion           String?
  horizon                LearningHorizon
  priceAtRecommendation  Decimal?               @db.Decimal(18, 0)
  priceAfter             Decimal?               @db.Decimal(18, 0)
  returnPct              Float?
  rewardScore            Float?
  evaluatedAt            DateTime               @default(now())
  metadata               Json?

  @@unique([recommendationResultId, horizon])
  @@index([modelVersion, horizon])
  @@index([evaluatedAt])
}

model PortfolioOutcome {
  id                 String          @id @default(cuid())
  userId             String?
  referenceKind      String
  referenceId        String
  horizon            LearningHorizon
  returnPct          Float?
  benchmarkReturnPct Float?
  rewardScore        Float?
  evaluatedAt        DateTime        @default(now())
  metadata           Json?

  @@unique([referenceKind, referenceId, horizon])
  @@index([userId, evaluatedAt])
}

model StrategyOutcome {
  id             String               @id @default(cuid())
  strategyName   BacktestStrategyName
  periodStart    DateTime             @db.Date
  periodEnd      DateTime             @db.Date
  totalReturn    Float?
  annualReturn   Float?
  maxDrawdown    Float?
  vsMedianPeer   Float?
  rankAmongPeers Int?
  rewardScore    Float?
  sampleTrades   Int?
  metadata       Json?
  createdAt      DateTime             @default(now())

  @@unique([strategyName, periodEnd])
  @@index([periodEnd])
}

/// اسنپ‌شات روزانهٔ لایهٔ یکپارچهٔ هوش (تلفیق خروجی موتورها)
model IntelligenceSnapshot {
  id             String   @id @default(cuid())
  /// یکتای روزانه، مثلاً `global:2026-03-30`
  snapshotKey    String   @unique
  snapshotDate   DateTime @db.Date
  marketOverview Json
  riskOverview   Json
  opportunities  Json
  alerts         Json
  decision       Json
  bestCars       Json
  bestPortfolio  Json
  bestStrategy   String?
  briefing       String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([snapshotDate])
}

/// سبد واقعی کاربر — دفتر کل، موقعیت‌ها، تراکنش و اسنپ‌شات عملکرد
model Portfolio {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String?
  baseCurrency String?  @default("IRR")
  createdAt    DateTime @default(now())

  positions    PortfolioPosition[]
  transactions PortfolioTransaction[]
  snapshots    PortfolioSnapshot[]

  @@index([userId, createdAt])
}

model PortfolioPosition {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  assetId     String
  assetType   String
  quantity    Float
  avgPrice    Float?
  marketValue Float?
  weight      Float?
  updatedAt   DateTime  @updatedAt

  @@unique([portfolioId, assetId, assetType])
  @@index([portfolioId])
}

model PortfolioTransaction {
  id                String           @id @default(cuid())
  portfolioId       String
  portfolio         Portfolio          @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  assetId           String
  assetType         String
  type              String
  quantity          Float
  price             Float
  amount            Float
  fee               Float?
  executionResultId String?
  executionResult   ExecutionResult? @relation(fields: [executionResultId], references: [id], onDelete: SetNull)
  executedAt        DateTime
  createdAt         DateTime         @default(now())

  @@index([portfolioId, executedAt])
  @@index([executionResultId])
}

model PortfolioSnapshot {
  id            String    @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  snapshotDate  DateTime
  totalValue    Float
  cashValue     Float
  investedValue Float
  return1d      Float?
  return7d      Float?
  return30d     Float?
  return90d     Float?
  sharpe        Float?
  volatility    Float?
  drawdown      Float?
  positions     Json
  createdAt     DateTime  @default(now())

  @@index([portfolioId, snapshotDate])
}
