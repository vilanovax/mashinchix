// Mashinchi — Car Decision Assistant (Iran market)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum UsageType {
  CITY
  FAMILY
  TRIP
  SPORT
  OFFROAD
  WORK_RIDEHAIL
  INVESTMENT
}

enum ListingCondition {
  NEW
  USED
  EITHER
}

enum UserEventType {
  PAGE_VIEW
  CAR_DETAIL_VIEW
  RECOMMENDATION_VIEW
  RECOMMENDATION_CLICK
  RECOMMENDATION_DISMISS
  WISHLIST_ADD
  WISHLIST_REMOVE
  COMPARE_ADD
  MARKET_SIGNAL_VIEW
  CONTACT_SELLER_CLICK
  FILTER_APPLY
  SEARCH
  PROFILE_UPDATE
}

enum RecommendationSource {
  MANUAL
  PROFILE_BASED
  SCENARIO_BASED
  API
  SYSTEM
}

model User {
  id                String            @id @default(cuid())
  name              String?
  budget            Decimal?          @db.Decimal(18, 0)
  riskLevel         RiskLevel?
  usageType         UsageType?
  usageTags         UsageType[]       @default([])
  listingCondition  ListingCondition?
  holdYears         Int?
  preferences       Json?
  previousCarIds    String[]          @default([])
  wizardCompletedAt DateTime?
  createdAt         DateTime          @default(now())

  wishlist UserWishlist[]
  profile  UserProfile?

  userEvents             UserEvent[]
  recommendationSessions RecommendationSession[]
  preferenceSignals      UserPreferenceSignal[]
  watchlistCars          UserWatchlist[]
  notifications          UserNotification[]
  personalizedInsights   PersonalizedInsight[]
  portfolioSimulations    PortfolioSimulation[]
  portfolioRecommendations UserPortfolioRecommendation[]
  decisionSnapshots      DecisionSnapshot[]
}

enum ListingSource {
  DIVAR
  BAMA
}

enum MarketCycleType {
  BULL
  BEAR
  STABLE
}

/// خروجی موتور تصمیم — اقدام در سطح بازار
enum DecisionMarketAction {
  BUY
  SELL
  HOLD
  WAIT
  CAUTIOUS
}

/// خروجی موتور تصمیم — سبد کاربر
enum DecisionPortfolioAction {
  REBALANCE
  HOLD
  REDUCE_RISK
  INCREASE_RISK
}

/// خروجی موتور تصمیم — نوع استراتژی پیشنهادی
enum DecisionStrategyAction {
  MOMENTUM
  LOW_RISK
  BALANCED
  CASH
  SEGMENT_ROTATION
}

enum DecisionMarketOutlook {
  BULL
  BEAR
  SIDEWAYS
}

/// روابط در گراف دانش خودرو
enum CarGraphRelationType {
  SIMILAR
  SUBSTITUTE
  COMPLEMENT
  PRICE_CORRELATED
  LIQUIDITY_CORRELATED
  RISK_CORRELATED
  MOMENTUM_CORRELATED
  SAME_SEGMENT
  COMPETITOR
  UPGRADE_PATH
}

/// روابط بین سگمنت‌ها در گراف بازار
enum SegmentGraphRelationType {
  INDEX_CORRELATED
  MOMENTUM_ALIGNED
  SUBSTITUTION_CLUSTER
  FLOW_LEADER_FOLLOWER
}

enum InsightType {
  FASTEST_RISING_PRICE
  FASTEST_FALLING_PRICE
  HIGH_MOMENTUM
  HIGH_VOLATILITY
  LOW_VOLATILITY
  UNDERVALUED
  OVERVALUED
  HIGH_DEMAND_LOW_SUPPLY
  HIGH_SUPPLY_LOW_DEMAND
  FASTEST_SELLING
  SLOWEST_SELLING
  ENTERING_BULL_TREND
  ENTERING_BEAR_TREND
  BEST_INVESTMENT_OPPORTUNITY
  HIGH_RISK_ALERT
  MARKET_TURNING_POINT
  SEGMENT_ROTATION
  LIQUIDITY_SPIKE
  DEMAND_SPIKE
}

enum MarketAlertType {
  PRICE_DROP
  VOLATILITY_SPIKE
  MARKET_ENTERING_BEAR
  MARKET_ENTERING_BULL
  CAR_ILLIQUID
  BEST_INVESTMENT_SIGNAL
  SEGMENT_OVERHEATING
  SEGMENT_CRASH_RISK
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum UserNotificationType {
  PRICE_DROP
  PRICE_RISE
  BUY_SIGNAL
  SELL_SIGNAL
  HIGH_RISK
  MARKET_ALERT
  INSIGHT
  WATCHLIST_UPDATE
  RECOMMENDATION
  MARKET_REPORT
}

enum PersonalizedInsightType {
  FAVORITE_SEGMENT_REGIME
  WATCHLIST_PRICE_CONTEXT
  SEGMENT_PEERS_MOMENTUM
  LOW_RISK_IN_BUDGET
  PROFILE_INVESTMENT_MATCH
  RECENT_BEHAVIOR_NUDGE
}

enum MarketReportFrequency {
  DAILY
  WEEKLY
}

enum BacktestStrategyName {
  BUY_ON_BUY_SIGNAL
  BUY_TOP_INVESTMENT_SCORE
  BUY_LOW_RISK
  BUY_HIGH_MOMENTUM
  BUY_UNDERVALUE
  SEGMENT_ROTATION
  MARKET_CYCLE_STRATEGY
  RECOMMENDATION_TOP1
  RECOMMENDATION_TOP3
  HOLD_LONG_TERM
  SELL_ON_SELL_SIGNAL
  RECOMMENDATION_HISTORICAL_EVAL
}

model Car {
  id     String @id @default(cuid())
  brand  String
  model  String
  year   Int
  bodyType String?
  segment  String?
  image    String?
  pros     String[] @default([])
  cons     String[] @default([])

  specs          CarSpecs?
  marketData     CarMarketData?
  scores         CarScores?
  ownershipCost  OwnershipCost?
  pricePrediction PricePrediction?
  reviewsRaw     CarReviewsRaw[]
  featureScores  CarFeatureScores[]
  priceHistory   PriceHistory[]
  listings       CarListing[]
  aliases        CarAlias[]

  wishlistedBy UserWishlist[]

  comparisonsAsA Comparison[] @relation("ComparisonCarA")
  comparisonsAsB Comparison[] @relation("ComparisonCarB")

  userEvents              UserEvent[]
  recommendationResults RecommendationResult[]
  behaviorMetricsDaily    CarBehaviorMetricsDaily[]
  liquidityStatsSnapshots CarLiquidityStats[]
  marketInsights          MarketInsight[]
  marketAlerts            MarketAlert[]
  userWatchlistEntries    UserWatchlist[]
  userNotifications       UserNotification[]
  personalizedInsights    PersonalizedInsight[]
  predictionEvaluations   PredictionEvaluation[]
  investmentEvaluations   InvestmentScoreEvaluation[]
  riskEvaluations         RiskScoreEvaluation[]
  relationshipsFrom       CarRelationship[]      @relation("CarGraphFrom")
  relationshipsTo         CarRelationship[]      @relation("CarGraphTo")
  similarityScoresAsCar   CarSimilarityScore[]   @relation("SimCar")
  similarityScoresAsPeer CarSimilarityScore[]  @relation("SimPeer")
}

/// رویداد رفتار کاربر / مهمان (ingestion سبک)
model UserEvent {
  id                      String         @id @default(cuid())
  userId                  String?
  user                    User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId               String
  eventType               UserEventType
  carId                   String?
  car                     Car?           @relation(fields: [carId], references: [id], onDelete: SetNull)
  recommendationSessionId String?
  recommendationSession   RecommendationSession? @relation(fields: [recommendationSessionId], references: [id], onDelete: SetNull)
  metadata                Json?
  createdAt               DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([carId, createdAt])
  @@index([recommendationSessionId, createdAt])
}

/// یک بار فراخوانی موتور توصیه (غیرقابل ویرایش پس از ایجاد)
model RecommendationSession {
  id             String                 @id @default(cuid())
  userId         String?
  user           User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId      String
  source         RecommendationSource
  requestPayload Json
  modelVersion   String
  createdAt      DateTime               @default(now())

  results RecommendationResult[]
  events  UserEvent[]
  performance RecommendationPerformance?

  @@index([userId, createdAt])
}

model RecommendationResult {
  id                      String                @id @default(cuid())
  recommendationSessionId String
  recommendationSession   RecommendationSession @relation(fields: [recommendationSessionId], references: [id], onDelete: Cascade)
  carId                   String
  car                     Car                   @relation(fields: [carId], references: [id], onDelete: Cascade)
  rank                    Int
  finalScore              Float
  explanation             Json?
  wasClicked              Boolean               @default(false)
  wasSaved                Boolean               @default(false)
  wasDismissed            Boolean               @default(false)
  createdAt               DateTime              @default(now())

  @@unique([recommendationSessionId, carId])
  @@index([recommendationSessionId, rank])
}

/// متریک رفتار روزانه به‌ازای خودرو (آمادهٔ یادگیری)
model CarBehaviorMetricsDaily {
  id                       String   @id @default(cuid())
  carId                    String
  car                      Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  snapshotDate             DateTime @db.Date
  detailViews              Int      @default(0)
  recommendationViews      Int      @default(0)
  recommendationClicks     Int      @default(0)
  recommendationDismisses  Int      @default(0)
  wishlistAdds             Int      @default(0)
  compareAdds              Int      @default(0)
  marketSignalViews        Int      @default(0)
  sellerClicks             Int      @default(0)
  ctrRecommendation        Float?
  saveRate                 Float?
  dismissRate              Float?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([carId, snapshotDate])
}

/// سیگنال ترجیح استنباط‌شده (جدا از UserProfile صریح)
model UserPreferenceSignal {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  signalDate        DateTime @db.Date
  preferredSegments String[] @default([])
  inferredWeights Json?
  favoriteCarIds  String[] @default([])
  confidenceScore Float?
  methodology       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([userId, signalDate])
  @@index([userId, signalDate])
}

/// عبارات مترادف / الگو برای مچ کردن عنوان آگهی به Car
model CarAlias {
  id           String          @id @default(cuid())
  carId        String
  car          Car             @relation(fields: [carId], references: [id], onDelete: Cascade)
  /// متن خام (برای نمایش در ادمین)
  alias        String
  /// نرمال‌شده برای تطبیق (یکتا در سطح سیستم)
  normalized   String          @unique
  /// محدود به منبع آگهی یا عمومی
  sourceFilter ListingSource?
  weight       Int             @default(0)
  isActive     Boolean         @default(true)
  createdAt    DateTime        @default(now())

  @@index([carId])
  @@index([isActive])
}

/// آگهی خام بازار (دیوار، باما و …)
model CarListing {
  id          String        @id @default(cuid())
  source      ListingSource
  /// شناسهٔ آگهی در سایت مبدأ (مثلاً token دیوار)
  externalId  String
  /// اگر با خودروی کاننیکال در DB مچ شد
  carId       String?
  car         Car?          @relation(fields: [carId], references: [id], onDelete: SetNull)
  price       Decimal       @db.Decimal(18, 0)
  mileageKm   Int?
  yearModel   Int?
  city        String?
  title       String?
  description String?       @db.Text
  listingUrl  String?
  listedAt    DateTime?
  scrapedAt   DateTime      @default(now())
  /// آخرین باری که آگهی در اسکرپ دیده شد (برای نرخ حذف / زمان فروش تقریبی)
  lastSeenAt  DateTime?
  rawPayload  Json?
  /// پاک‌سازی داده: حذف از متریک/تجمیع
  isExcluded       Boolean  @default(false)
  exclusionReason  String?

  @@unique([source, externalId])
  @@index([carId])
  @@index([source, scrapedAt])
  @@index([listedAt])
}

model CarSpecs {
  id              String  @id @default(cuid())
  carId           String  @unique
  car             Car     @relation(fields: [carId], references: [id], onDelete: Cascade)
  engine          String?
  horsepower      Int?
  torque          String?
  gearbox         String?
  transmission    String?
  fuelType        String?
  fuelConsumption String?
  acceleration    String?
  maxSpeed        Int?
  weight          Int?
  trunk           Int?
}

model CarMarketData {
  id             String   @id @default(cuid())
  carId          String   @unique
  car            Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  avgPrice       Decimal? @db.Decimal(18, 0)
  minPrice       Decimal? @db.Decimal(18, 0)
  maxPrice       Decimal? @db.Decimal(18, 0)
  adsCount       Int      @default(0)
  priceChange30d Decimal? @db.Decimal(8, 4)
  priceChange1y  Decimal? @db.Decimal(8, 4)
  liquidityScore Float?
  /// نرخ افت قیمت تجمعی اخیر (مثلاً ۳۰ روز ، نسبت به میانگین دوره قبل)
  depreciationRate30d Decimal? @db.Decimal(8, 4)
  /// روند قیمت: شیب نرمال‌شده حدود ۱- تا ۱+
  priceTrendScore     Float?
  /// برچسب قابل‌نمایش: RISING | STABLE | FALLING
  priceTrendLabel     String?
  /// تقاضا: ترکیب رشد تعداد آگهی‌های تازه و حجم فعال
  demandScore         Float?
  /// نوسان قیمت روزانه از تاریخچه (۰=پر نوسان … 100=ثبات نسبی)
  volatilityScore     Float?
  /// انحراف معیار بازده‌های روزانه قیمت
  volatilityRaw       Float?
  /// RISING | STABLE | FALLING — روند حجم آگهی ۷ روز اخیر vs قبلی
  popularityTrend     String?
  popularityTrendScore Float?
  buyScore            Float?
  sellScore           Float?
  /// BUY | SELL | HOLD
  marketSignal        String?
  /// مومنتوم قیمت از تاریخچه (نسبت)
  priceChange7d       Decimal? @db.Decimal(8, 4)
  priceChange90d      Decimal? @db.Decimal(8, 4)
  momentumScore       Float?
  listingsLast7d      Int?
  listingsPrev7d      Int?
  listingsLast30d     Int?
  listingsPrev30d     Int?
  liquidityTrendScore Float?
  liquidityTrendLabel String?
  volatilityTrendScore Float?
  volatilityTrendLabel String?
  metricsComputedAt   DateTime?
  updatedAt      DateTime @updatedAt
}

model CarScores {
  id               String   @id @default(cuid())
  carId            String   @unique
  car              Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  performanceScore Float?
  comfortScore     Float?
  economyScore     Float?
  reliabilityScore Float?
  marketScore      Float?
  ownershipScore   Float?
  prestigeScore    Float?
  riskScore        Float?
  overallScore     Float?
  /// ترکیب حجم آگهی، تقاضا و تعداد نظرات
  popularityScore         Float?
  /// رضایت مالک از تحلیل احساس NLP روی ابعاد کلیدی
  ownerSatisfactionScore  Float?
  /// RISING | STABLE | FALLING — مقایسهٔ احساس نظرات ۹۰ روز اخیر vs ۹۰ روز قبل
  ownerSatisfactionTrend  String?
  ownerSatisfactionTrendScore Float?
  /// جذابیت سرمایه‌گذاری (افت، نقدشوندگی، تقاضا، پیش‌بینی قیمت)
  investmentScore         Float?
  /// نسخهٔ فرمول overall (مثلاً v3-dynamic)
  modelVersion     String?
  updatedAt        DateTime @updatedAt
}

/// نقدشوندگی و زمان تقریبی فروش (نقطهٔ زمانی)
model CarLiquidityStats {
  id               String   @id @default(cuid())
  carId            String
  car              Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  snapshotDate     DateTime @db.Date
  avgDaysToSell    Float?
  medianDaysToSell Float?
  sellThroughRate  Float?
  createdAt        DateTime @default(now())

  @@unique([carId, snapshotDate])
  @@index([carId, snapshotDate])
}

/// چرخهٔ بازار به‌ازای سگمنت (روزانه)
model MarketCycle {
  id              String          @id @default(cuid())
  segment         String
  snapshotDate    DateTime        @db.Date
  cycleType       MarketCycleType
  confidenceScore Float?
  methodology     String?
  createdAt       DateTime        @default(now())

  @@unique([segment, snapshotDate])
  @@index([segment, snapshotDate])
}

/// پیش‌بینی قیمت از روند خطی روی تاریخچهٔ قیمت
model PricePrediction {
  id                 String   @id @default(cuid())
  carId              String   @unique
  car                Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  predictedPrice30d  Decimal? @db.Decimal(18, 0)
  predictedPrice90d  Decimal? @db.Decimal(18, 0)
  predictedChange30d Decimal? @db.Decimal(8, 4)
  predictedChange90d Decimal? @db.Decimal(8, 4)
  confidence         Float?
  historyPointsUsed  Int?
  methodology        String?
  computedAt         DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// شاخص ترکیبی بازار به‌ازای هر سگمنت (نقطهٔ زمانی)
model SegmentMarketIndex {
  id                     String   @id @default(cuid())
  segment                String
  snapshotDate           DateTime @db.Date
  indexValue             Float
  avgPredictedChange30d  Float?
  liquidityAvg           Float?
  demandAvg              Float?
  carCount               Int
  methodology            String?
  createdAt              DateTime @default(now())

  @@unique([segment, snapshotDate])
  @@index([segment, snapshotDate])
}

/// بینش خودکار بازار (روزانه / اجرای job)
model MarketInsight {
  id           String      @id @default(cuid())
  insightType  InsightType
  carId        String?
  car          Car?        @relation(fields: [carId], references: [id], onDelete: SetNull)
  segment      String?
  title        String
  description  String      @db.Text
  /// اهمیت یا قدرت سیگنال (۰–۱۰۰)
  score        Float
  metadata     Json?
  snapshotDate DateTime    @db.Date
  createdAt    DateTime    @default(now())

  @@index([insightType, snapshotDate])
  @@index([carId, snapshotDate])
  @@index([segment, snapshotDate])
  @@index([snapshotDate])
}

model MarketAlert {
  id         String          @id @default(cuid())
  alertType  MarketAlertType
  carId      String?
  car        Car?            @relation(fields: [carId], references: [id], onDelete: SetNull)
  segment    String?
  message    String          @db.Text
  severity   AlertSeverity
  metadata   Json?
  createdAt  DateTime        @default(now())
  isActive   Boolean         @default(true)

  @@index([alertType, isActive])
  @@index([carId, isActive])
  @@index([segment, isActive])
  @@index([createdAt])
}

/// لیست رصد کاربر (هدف قیمت، هشدارها)
model UserWatchlist {
  id                 String   @id @default(cuid())
  userId             String
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId              String
  car                Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  notes              String?
  targetBuyPrice     Decimal? @db.Decimal(18, 0)
  targetSellPrice    Decimal? @db.Decimal(18, 0)
  alertOnPriceDrop   Boolean  @default(true)
  alertOnPriceRise   Boolean  @default(false)
  alertOnBuySignal   Boolean  @default(true)
  alertOnSellSignal  Boolean  @default(true)
  alertOnHighRisk    Boolean  @default(true)
  alertOnMomentum    Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([userId, carId])
  @@index([userId])
  @@index([carId])
}

model UserNotification {
  id        String               @id @default(cuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      UserNotificationType
  title     String
  message   String               @db.Text
  carId     String?
  car       Car?                 @relation(fields: [carId], references: [id], onDelete: SetNull)
  segment   String?
  metadata  Json?
  isRead    Boolean              @default(false)
  createdAt DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([userId, isRead])
  @@index([carId])
}

model MarketReport {
  id                   String                @id @default(cuid())
  reportDate           DateTime              @db.Date
  frequency            MarketReportFrequency @default(DAILY)
  title                String
  summary              String                @db.Text
  marketCycle          Json
  topRisingCars        Json
  topFallingCars       Json
  bestInvestments      Json
  highestRiskCars      Json
  fastestSellingCars   Json
  segmentTrends        Json
  volatilityOverview   Json
  liquidityOverview    Json
  metadata             Json?
  createdAt            DateTime              @default(now())

  @@unique([reportDate, frequency])
  @@index([reportDate])
}

model PersonalizedInsight {
  id             String                  @id @default(cuid())
  userId         String
  user           User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  insightType    PersonalizedInsightType
  carId          String?
  car            Car?                    @relation(fields: [carId], references: [id], onDelete: SetNull)
  segment        String?
  title          String
  description    String                  @db.Text
  score          Float
  metadata       Json?
  createdAt      DateTime                @default(now())

  @@index([userId, createdAt])
  @@index([insightType])
}

model ApiKey {
  id         String   @id @default(cuid())
  key        String   @unique
  name       String
  isActive   Boolean  @default(true)
  rateLimit  Int      @default(60)
  createdAt  DateTime @default(now())
}

/// ترجیحات ساخت‌یافته برای موتور توصیهٔ v2 (کنار فیلدهای User)
model UserProfile {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// { "performance": 1.2, "economy": 0.8, ... }
  scoreWeights            Json?
  preferredSegments     String[] @default([])
  minBudget             Decimal? @db.Decimal(18, 0)
  maxBudget             Decimal?  @db.Decimal(18, 0)
  investmentBias          Float?
  holdHorizonMonths       Int?
  popularityWeight        Float?
  ownerSatisfactionWeight Float?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

/// تخمین هزینهٔ مالکیت (مدل v2 — مقادیر تقریبی)
model OwnershipCost {
  id                       String   @id @default(cuid())
  carId                    String   @unique
  car                      Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  /// هزینه سوخت تقریبی ماهانه (تومان)
  fuelMonthlyTomans        Decimal? @db.Decimal(18, 0)
  /// هزینه نگهداری تقریبی سالانه (تومان)
  maintenanceYearlyTomans  Decimal? @db.Decimal(18, 0)
  /// نرخ افت ارزش سالانه تخمینی (نسبت، مثلاً 0.12 = 12٪)
  depreciationAnnualRate   Decimal? @db.Decimal(8, 4)
  methodology              String?
  computedAt               DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model CarReviewsRaw {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  source    String
  text      String   @db.Text
  fetchedAt DateTime @default(now())
  /// شناسهٔ خارجی برای ددیاب (youtube_id، comment_id، …)
  externalId   String?
  title        String?
  lang         String   @default("fa")
  /// متادیتای خام (لینک، نویسنده، …)
  rawMetadata  Json?
  /// هش متن برای جلوگیری از تکرار
  contentHash  String?

  @@unique([carId, contentHash])
  @@index([carId])
  @@index([carId, source])
  @@index([source, externalId])
}

model CarFeatureScores {
  id            String  @id @default(cuid())
  carId         String
  car           Car     @relation(fields: [carId], references: [id], onDelete: Cascade)
  feature       String
  positiveCount Int     @default(0)
  negativeCount Int     @default(0)
  score         Float?

  @@unique([carId, feature])
  @@index([carId])
}

model Comparison {
  id               String   @id @default(cuid())
  carAId           String
  carBId           String
  carA             Car      @relation("ComparisonCarA", fields: [carAId], references: [id], onDelete: Cascade)
  carB             Car      @relation("ComparisonCarB", fields: [carBId], references: [id], onDelete: Cascade)
  economicWinner   String?
  familyWinner     String?
  sportWinner      String?
  cityWinner       String?
  tripWinner       String?
  investmentWinner String?
  createdAt        DateTime @default(now())

  @@unique([carAId, carBId])
}

model PriceHistory {
  id           String   @id @default(cuid())
  carId        String
  car          Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  date         DateTime @db.Date
  price        Decimal  @db.Decimal(18, 0)
  /// تعداد آگهی‌های تجمیع‌شده برای این روز (در صورت availability)
  listingCount Int?

  @@unique([carId, date])
  @@index([carId, date])
}

model UserWishlist {
  userId String
  carId  String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  car    Car  @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@id([userId, carId])
}

model BacktestResult {
  id            String               @id @default(cuid())
  strategyName  BacktestStrategyName
  startDate     DateTime             @db.Date
  endDate       DateTime             @db.Date
  totalReturn   Float
  annualReturn  Float
  maxDrawdown   Float
  winRate       Float
  tradesCount   Int
  metadata      Json?
  createdAt     DateTime             @default(now())

  @@index([strategyName, createdAt])
  @@index([startDate, endDate])
}

model PortfolioSimulation {
  id              String               @id @default(cuid())
  userId          String?
  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  strategy        BacktestStrategyName
  startDate       DateTime             @db.Date
  endDate         DateTime             @db.Date
  initialCapital  Decimal              @db.Decimal(18, 2)
  finalCapital    Decimal              @db.Decimal(18, 2)
  totalReturn     Float
  maxDrawdown     Float
  metadata        Json?
  createdAt       DateTime             @default(now())

  @@index([userId, createdAt])
  @@index([strategy])
}

model PredictionEvaluation {
  id             String   @id @default(cuid())
  carId          String
  car            Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  predictionDate DateTime @db.Date
  targetDate     DateTime @db.Date
  horizonDays    Int
  predictedPrice Decimal  @db.Decimal(18, 0)
  actualPrice    Decimal? @db.Decimal(18, 0)
  error          Float?
  absError       Float?
  pctError       Float?
  modelVersion   String
  createdAt      DateTime @default(now())

  @@unique([carId, predictionDate, horizonDays, modelVersion])
  @@index([carId])
  @@index([targetDate])
  @@index([modelVersion])
}

model InvestmentScoreEvaluation {
  id               String   @id @default(cuid())
  carId            String
  car              Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  snapshotDate     DateTime @db.Date
  investmentScore  Float
  return30d        Float?
  return90d        Float?
  return180d       Float?
  volatility       Float?
  drawdown         Float?
  createdAt        DateTime @default(now())

  @@unique([carId, snapshotDate])
  @@index([snapshotDate])
}

model RiskScoreEvaluation {
  id                 String   @id @default(cuid())
  carId              String
  car                Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  snapshotDate       DateTime @db.Date
  riskScore          Float
  futureVolatility   Float?
  futureDrawdown     Float?
  futureReturn       Float?
  createdAt          DateTime @default(now())

  @@unique([carId, snapshotDate])
  @@index([snapshotDate])
}

model RecommendationPerformance {
  id                     String                @id @default(cuid())
  recommendationSessionId String               @unique
  recommendationSession  RecommendationSession @relation(fields: [recommendationSessionId], references: [id], onDelete: Cascade)
  avgReturn7d            Float?
  avgReturn30d           Float?
  avgReturn90d           Float?
  clicked                Boolean               @default(false)
  saved                  Boolean               @default(false)
  dismissed              Boolean               @default(false)
  createdAt              DateTime              @default(now())
}

model ScoreCalibration {
  id           String   @id @default(cuid())
  modelName    String
  parameter    String
  oldWeight    Float
  newWeight    Float
  methodology  String?
  createdAt    DateTime @default(now())

  @@index([modelName, createdAt])
}

/// نقطهٔ جبههٔ کارا (ریسک-بازده) برای نمودار؛ allocation آرایهٔ وزن به‌ازای خودرو
model PortfolioFrontier {
  id           String   @id @default(cuid())
  risk         Float
  return       Float
  allocation   Json
  methodology  String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

/// آخرین توصیهٔ سبد ذخیره‌شده برای کاربر (اختیاری)
model UserPortfolioRecommendation {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  budget    Decimal? @db.Decimal(18, 0)
  params    Json
  result    Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// سناریوی بازار برای شبیه‌سازی و استرس‌تست
model MarketScenario {
  id                   String   @id @default(cuid())
  name                 String
  description          String   @db.Text
  /// تغییر تجمعی هدف قیمت (درصد) در افق شبیه‌سازی
  priceChangePct       Float
  volatilityMultiplier Float    @default(1)
  liquidityMultiplier  Float    @default(1)
  demandMultiplier     Float    @default(1)
  /// اختیاری: بازتعریف به‌ازای سگمنت، مثلاً { "suv": { "priceChangePct": -30 } }
  segmentOverrides     Json?
  durationDays         Int      @default(252)
  createdAt            DateTime @default(now())

  portfolioStressTests       PortfolioStressTest[]
  strategyScenarioPerformances StrategyScenarioPerformance[]

  @@index([name])
}

/// نتیجهٔ استرس‌تست روی یک سبد (آرشیو)
model PortfolioStressTest {
  id                  String         @id @default(cuid())
  /// { carIds: string[], weights: number[], budget?: number }
  portfolio           Json
  scenarioId          String
  scenario            MarketScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  finalReturn         Float?
  maxDrawdown         Float
  recoveryTimeDays    Int?
  lossProbability     Float?
  volatility          Float?
  worstCase           Float?
  bestCase            Float?
  survivalProbability Float?
  raw                 Json?
  createdAt           DateTime       @default(now())

  @@index([scenarioId, createdAt])
}

/// عملکرد استراتژی بک‌تست تحت سناریو (شوک روی مسیر تاریخی)
model StrategyScenarioPerformance {
  id                  String               @id @default(cuid())
  strategyName        BacktestStrategyName
  scenarioId          String
  scenario            MarketScenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  finalReturn         Float?
  maxDrawdown         Float
  survivalProbability Float?
  timeToRecoveryDays  Int?
  methodology         String?
  createdAt           DateTime             @default(now())

  @@unique([strategyName, scenarioId])
  @@index([scenarioId])
}

/// اسنپ‌شات روزانهٔ تصمیم سیستم (بازار یا شخصی‌سازی‌شده با userId)
model DecisionSnapshot {
  id                  String               @id @default(cuid())
  ///کلید یکتا: `market:YYYY-MM-DD` یا `user:{userId}:YYYY-MM-DD`
  snapshotKey         String               @unique
  snapshotDate        DateTime             @db.Date
  userId              String?
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  marketDecision      DecisionMarketAction
  portfolioDecision   DecisionPortfolioAction
  strategyDecision    DecisionStrategyAction
  /// خلاصهٔ چرخه، مثلاً «۶۵٪ سگمنت‌ها گاوی»
  marketCycle         String?
  marketOutlook       DecisionMarketOutlook
  riskLevel           RiskLevel
  confidence          Float
  summary             String               @db.Text
  keyFactors          Json
  warnings            Json
  opportunities       Json
  /// bestSegments، avoidSegments، bestCarsToBuy، carsToSell و متادیتا
  details             Json?
  createdAt           DateTime             @default(now())

  @@index([snapshotDate])
  @@index([userId, snapshotDate])
}

/// یال گراف بین دو خودرو
model CarRelationship {
  id           String              @id @default(cuid())
  carId        String
  relatedCarId String
  car          Car                 @relation("CarGraphFrom", fields: [carId], references: [id], onDelete: Cascade)
  relatedCar   Car                 @relation("CarGraphTo", fields: [relatedCarId], references: [id], onDelete: Cascade)
  relationType CarGraphRelationType
  strength     Float
  methodology  String?
  createdAt    DateTime            @default(now())

  @@unique([carId, relatedCarId, relationType])
  @@index([carId])
  @@index([relatedCarId])
  @@index([relationType])
}

/// یال گراف بین سگمنت‌ها
model SegmentRelationship {
  id             String                 @id @default(cuid())
  segment        String
  relatedSegment String
  relationType   SegmentGraphRelationType
  correlation    Float
  methodology    String?
  createdAt      DateTime               @default(now())

  @@unique([segment, relatedSegment, relationType])
  @@index([segment])
  @@index([relatedSegment])
}

/// امتیاز تشابه ترکیبی (۰–۱) برای جفت خودرو
model CarSimilarityScore {
  id              String   @id @default(cuid())
  carId           String
  peerCarId       String
  car             Car      @relation("SimCar", fields: [carId], references: [id], onDelete: Cascade)
  peer            Car      @relation("SimPeer", fields: [peerCarId], references: [id], onDelete: Cascade)
  score           Float
  specSim         Float?
  priceSim        Float?
  corrSim         Float?
  behaviorCooccur Float?
  ownershipSim    Float?
  components      Json?
  methodology     String?
  createdAt       DateTime @default(now())

  @@unique([carId, peerCarId])
  @@index([carId])
  @@index([peerCarId])
}

/// خروجی ذخیره‌شدهٔ بهینه‌سازی سبد
model PortfolioOptimizationResult {
  id                   String   @id @default(cuid())
  methodology          String
  carIds               String[] @default([])
  weights              Json
  expectedReturn       Float
  expectedVolatility   Float
  sharpeRatio          Float?
  maxDrawdown          Float?
  diversificationScore Float
  riskContribution     Json
  constraints          Json
  createdAt            DateTime @default(now())

  @@index([methodology, createdAt])
}
