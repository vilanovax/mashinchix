model PortfolioFrontier {
  id           String   @id @default(cuid())
  risk         Float
  return       Float
  allocation   Json
  methodology  String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

/// آخرین توصیهٔ سبد ذخیره‌شده برای کاربر (اختیاری)
model UserPortfolioRecommendation {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  budget    Decimal? @db.Decimal(18, 0)
  params    Json
  result    Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

/// سناریوی بازار برای شبیه‌سازی و استرس‌تست
model MarketScenario {
  id                   String   @id @default(cuid())
  name                 String
  description          String   @db.Text
  /// تغییر تجمعی هدف قیمت (درصد) در افق شبیه‌سازی
  priceChangePct       Float
  volatilityMultiplier Float    @default(1)
  liquidityMultiplier  Float    @default(1)
  demandMultiplier     Float    @default(1)
  /// اختیاری: بازتعریف به‌ازای سگمنت، مثلاً { "suv": { "priceChangePct": -30 } }
  segmentOverrides     Json?
  durationDays         Int      @default(252)
  createdAt            DateTime @default(now())

  portfolioStressTests       PortfolioStressTest[]
  strategyScenarioPerformances StrategyScenarioPerformance[]

  @@index([name])
}

/// نتیجهٔ استرس‌تست روی یک سبد (آرشیو)
model PortfolioStressTest {
  id                  String         @id @default(cuid())
  /// { carIds: string[], weights: number[], budget?: number }
  portfolio           Json
  scenarioId          String
  scenario            MarketScenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  finalReturn         Float?
  maxDrawdown         Float
  recoveryTimeDays    Int?
  lossProbability     Float?
  volatility          Float?
  worstCase           Float?
  bestCase            Float?
  survivalProbability Float?
  raw                 Json?
  createdAt           DateTime       @default(now())

  @@index([scenarioId, createdAt])
}

/// عملکرد استراتژی بک‌تست تحت سناریو (شوک روی مسیر تاریخی)
model StrategyScenarioPerformance {
  id                  String               @id @default(cuid())
  strategyName        BacktestStrategyName
  scenarioId          String
  scenario            MarketScenario       @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  finalReturn         Float?
  maxDrawdown         Float
  survivalProbability Float?
  timeToRecoveryDays  Int?
  methodology         String?
  createdAt           DateTime             @default(now())

  @@unique([strategyName, scenarioId])
  @@index([scenarioId])
}

/// اسنپ‌شات روزانهٔ تصمیم سیستم (بازار یا شخصی‌سازی‌شده با userId)
model DecisionSnapshot {
  id                  String               @id @default(cuid())
  ///کلید یکتا: `market:YYYY-MM-DD` یا `user:{userId}:YYYY-MM-DD`
  snapshotKey         String               @unique
  snapshotDate        DateTime             @db.Date
  userId              String?
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  marketDecision      DecisionMarketAction
  portfolioDecision   DecisionPortfolioAction
  strategyDecision    DecisionStrategyAction
  /// خلاصهٔ چرخه، مثلاً «۶۵٪ سگمنت‌ها گاوی»
  marketCycle         String?
  marketOutlook       DecisionMarketOutlook
  riskLevel           RiskLevel
  confidence          Float
  summary             String               @db.Text
  keyFactors          Json
  warnings            Json
  opportunities       Json
  /// bestSegments، avoidSegments، bestCarsToBuy، carsToSell و متادیتا
  details             Json?
  createdAt           DateTime             @default(now())

  decisionOutcomes    DecisionOutcome[]
  userDecisionFeedbacks UserDecisionFeedback[]

  @@index([snapshotDate])
  @@index([userId, snapshotDate])
}

/// رفتار و بازخورد کاربر نسبت به مشاور / اجرا / تصمیم
model UserAction {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionType    String
  planId        String?
  plan          ExecutionPlan?   @relation(fields: [planId], references: [id], onDelete: SetNull)
  executionId   String?
  executionResult ExecutionResult? @relation(fields: [executionId], references: [id], onDelete: SetNull)
  assetId       String?
  action        String
  value         Float?
  metadata      Json?
  createdAt     DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([planId])
}

/// پروفایل رفتاری تجمیعی برای شخصی‌سازی موتورها
model UserBehaviorProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  riskTolerance       Float?
  panicSellScore      Float?
  holdDuration        Float?
  diversificationPref Float?
  liquidityPref       Float?
  momentumPref        Float?
  valuePref           Float?
  confidenceTrust     Float?
  overrideRate        Float?
  segmentPreferences  Json?
  strategyPreferences Json?
  updatedAt           DateTime   @updatedAt
}

model UserDecisionFeedback {
  id         String           @id @default(cuid())
  userId     String
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  decisionId String
  decision   DecisionSnapshot @relation(fields: [decisionId], references: [id], onDelete: Cascade)
  feedback   String
  rating     Float?
  note       String?          @db.Text
  createdAt  DateTime         @default(now())

  @@index([userId, decisionId])
  @@index([decisionId])
}

/// پلان اقدامات پیشنهادی موتور اجرا (بدون اجرای واقعی معامله)
model ExecutionPlan {
  id             String    @id @default(cuid())
  userId         String?
  user           User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  planDate       DateTime  @db.Date
  actions        Json
  summary        String    @db.Text
  expectedReturn Float?
  expectedRisk   Float?
  confidence     Float?
  simulation     Json?
  createdAt      DateTime  @default(now())

  simulations ExecutionSimulation[]
  results     ExecutionResult[]
  approvals   ExecutionApproval[]
  userActions UserAction[]

  @@index([userId, planDate])
  @@index([planDate])
}

/// شبیه‌سازی پیش‌از اجرای پلان (Pre-Trade Risk)
model ExecutionSimulation {
  id                   String        @id @default(cuid())
  planId               String
  plan                 ExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  expectedReturn       Float
  expectedRisk         Float
  expectedSharpe       Float
  expectedDrawdown     Float
  diversificationScore Float?
  stressDrawdown       Float?
  portfolioBefore      Json?
  portfolioAfter       Json
  stressScenarioId     String?
  createdAt            DateTime      @default(now())

  @@index([planId, createdAt])
}

model ExecutionPolicy {
  id                   String   @id @default(cuid())
  actionType           String
  autoExecute          Boolean  @default(false)
  requireApproval      Boolean  @default(true)
  maxAllocationChange  Float?
  maxTradeAmount       Float?
  maxPortfolioRisk     Float?
  maxDrawdownAllowed   Float?
  minConfidenceAuto    Float?
  createdAt            DateTime @default(now())

  @@unique([actionType])
  @@index([actionType])
}

model ExecutionApproval {
  id         String        @id @default(cuid())
  planId     String
  plan       ExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  approved   Boolean
  approvedAt DateTime?
  note       String?       @db.Text
  createdAt  DateTime      @default(now())

  @@index([planId, userId])
  @@index([userId, createdAt])
}

/// نتیجهٔ اجرای (یا شبیه‌سازی نهایی) هر اکشن / پلان
model ExecutionResult {
  id                String        @id @default(cuid())
  planId            String
  plan              ExecutionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId            String?
  user              User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  actionType        String
  status            String
  expectedReturn    Float?
  realizedReturn    Float?
  expectedRisk      Float?
  realizedRisk      Float?
  expectedSharpe    Float?
  realizedSharpe    Float?
  slippage          Float?
  transactionCost   Float?
  portfolioBefore   Json?
  portfolioAfter    Json?

  executedAt DateTime @default(now())
  metadata   Json?
  outcome    ExecutionOutcome?
  portfolioTransactions PortfolioTransaction[]
  userActions           UserAction[]

  @@index([planId, executedAt])
  @@index([userId, executedAt])
  @@index([actionType, status])
